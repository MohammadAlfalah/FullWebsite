@model Domain.DTOs.ProductDTO
@using Microsoft.AspNetCore.Mvc.Rendering

<div class="card shadow border-0 my-4">
    <div class="card-header bg-dark bg-gradient m0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Create Product</h2>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <form method="post" class="row">

            <div class="form-floating py-2 col-12">
                <input asp-for="Name" class="form-control border-0 shadow" />
                <label asp-for="Name" class="text-black ms-2"></label>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-floating py-2 col-12">
                <input asp-for="OldPrice" class="form-control border-0 shadow" />
                <label asp-for="OldPrice" class="ms-2"></label>
                <span asp-validation-for="OldPrice" class="text-danger"></span>
            </div>

            <div class="form-floating py-2 col-12">
                <input asp-for="NewPrice" class="form-control border-0 shadow" />
                <label asp-for="NewPrice" class="ms-2"></label>
                <span asp-validation-for="NewPrice" class="text-danger"></span>
            </div>

            <div class="py-2 col-12">
                <label asp-for="CategoryId" class="ms-2 mb-1"></label>
                <select asp-for="CategoryId" asp-items="@(ViewBag.CategoryList as IEnumerable<SelectListItem>)" class="form-select border-0 shadow"></select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-start align-items-center gap-3 pt-2">
                <button type="submit" class="btn btn-dark bg-gradient">Create</button>
                <a asp-area="AdminV" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary border-1">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
